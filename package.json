{
  "name": "qa-automation-test",
  "version": "1.0.0",
  "description": "QA Automation technical test using WebdriverIO, Cucumber and TypeScript",
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:chrome": "wdio run ./wdio.conf.ts --browser chrome",
    "test:firefox": "wdio run ./wdio.conf.ts --browser firefox",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "test:report": "npm run test && npm run report:generate",
    "test:qa": "cross-env TEST_ENV=qa wdio run ./wdio.conf.ts",
    "test:staging": "cross-env TEST_ENV=staging wdio run ./wdio.conf.ts"
  },
  "keywords": [
    "webdriverio",
    "cucumber",
    "typescript",
    "qa",
    "automation"
  ],
  "author": "Ignacio Heredia",
  "license": "MIT",
  "devDependencies": {
    "@wdio/cli": "^9.15.0",
    "@wdio/cucumber-framework": "^9.15.0",
    "@wdio/local-runner": "^9.15.0",
    "@wdio/spec-reporter": "^9.15.0",
    "@wdio/globals": "^9.15.0",
    "typescript": "^5.8.3",
    "ts-node": "^10.9.2",
    "expect-webdriverio": "^5.4.0",
    "@wdio/allure-reporter": "^9.15.0",
    "allure-commandline": "^2.34.1",
    "dotenv": "^16.4.5",
    "cross-env": "^7.0.3"
  }
}